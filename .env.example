# Copy this file to .env and fill in your values.
# .env is never uploaded to GitHub (it's in .gitignore).

# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# --- Registration gate ---
# When set, /register requires this access code before the signup form is shown.
# Keeps the app hidden from the public landing page while letting invited people
# (those you've booked calls with) create accounts. Leave empty for no gate.
# REGISTER_GATE_PASSWORD=choose-a-shared-access-code

# --- Landing-page inquiries ---
# Where the "Inquire" form on the public landing page sends submissions.
# Defaults to comet@cometinc.ca. Email only sends if MAIL_SERVER is configured above;
# either way the inquiry is saved to the database.
# INQUIRY_NOTIFY_EMAIL=comet@cometinc.ca

# --- Email (password reset) — without MAIL_SERVER, no real email is sent; check password_reset_last_link.txt ---
# Gmail example: enable 2FA, create an App Password (Google Account → Security → App passwords),
# then use that 16-character value as MAIL_PASSWORD (not your normal Gmail password).
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=youraccount@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# MAIL_FROM=youraccount@gmail.com
# Optional: send ALL reset emails here (overrides the form’s “Send password reset email to” field):
# PASSWORD_RESET_EMAIL_TO=you@example.com
